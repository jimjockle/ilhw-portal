# Supabase Configuration
# Create a project at https://supabase.com and fill these in
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Claude API (for chatbot preview)
ANTHROPIC_API_KEY=your-anthropic-key-here

# Dataset URL (points to the chatbot's dataset.json)
NEXT_PUBLIC_DATASET_URL=https://ilhw-chatbot.vercel.app/dataset.json
